{
  "expo": {
    "name": "Converti",
    "slug": "converti",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/converti_icon_white.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/background/logo_white.png",
      "resizeMode": "contain",
      "backgroundColor": "#212738"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.faculdade.converti",
      "adaptiveIcon": {
        "backgroundColor": "#212738",
        "foregroundImage": "./assets/converti_icon_white.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "45e502cd-a1de-40b4-80d5-a0940ada1eae"
      }
    }
  }
}
